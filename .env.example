# Token do bot, gerado pelo @BotFather no Telegram.
# Nunca faça commit deste valor — use .env localmente e variáveis de ambiente na Vercel.
BOT_TOKEN=

# Endpoint da API que extrai o vídeo da Shopee.
# É apenas uma API HTTP comum (não estamos usando o SDK do Supabase).
SHOPEE_API_URL=https://hwdahtwlpjlwrmkgimvq.supabase.co/functions/v1/shopee-extractor

# Token secreto do webhook do Telegram (recomendado).
# O Telegram envia este valor no header X-Telegram-Bot-Api-Secret-Token,
# e nós validamos antes de processar a requisição.
# Use uma string aleatória forte (ex.: openssl rand -hex 32).
TELEGRAM_WEBHOOK_SECRET=

# Domínio público da Vercel onde o bot está hospedado.
# Usado apenas pelo script scripts/set-webhook.js.
# Ex.: https://meu-bot.vercel.app
PUBLIC_URL=

# -----------------------------------------------------------------------------
# Integração com o site shopeedownloader.com (premium / free / cota)
# -----------------------------------------------------------------------------

# Domínio base do site. Os endpoints serão chamados em <SITE_API_URL>/api/bot/*
SITE_API_URL=https://www.shopeedownloader.com

# Segredo compartilhado bot ↔ site. O bot envia em X-Bot-Secret e o site
# valida — sem isso, qualquer pessoa poderia consumir cota dos seus usuários.
# Use uma string aleatória forte (ex.: openssl rand -hex 32).
SITE_API_KEY=

# (Opcional) URL pública do site mostrada nas mensagens do bot.
# Se não definir, usa SITE_API_URL.
SITE_PUBLIC_URL=https://www.shopeedownloader.com
