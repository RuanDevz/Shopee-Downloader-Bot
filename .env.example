# =============================================================================
# Variáveis de ambiente do bot.
# Copie este arquivo para `.env` e preencha. NUNCA versione o `.env` real.
# =============================================================================

# --- Telegram ----------------------------------------------------------------

# Token do bot, gerado pelo @BotFather no Telegram.
BOT_TOKEN=

# Username do bot (sem @). Usado no link de retorno após o pagamento.
# Ex.: ShopeeDownloaderBot
BOT_USERNAME=

# Token secreto do webhook do Telegram (recomendado).
# O Telegram envia este valor no header X-Telegram-Bot-Api-Secret-Token,
# e nós validamos antes de processar a requisição.
# Gere com: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Domínio público da Vercel onde o bot está hospedado.
# Usado pelo script scripts/set-webhook.js.
# Ex.: https://meu-bot.vercel.app
PUBLIC_URL=

# --- Shopee API --------------------------------------------------------------

# Endpoint da API que extrai o vídeo da Shopee.
SHOPEE_API_URL=https://hwdahtwlpjlwrmkgimvq.supabase.co/functions/v1/shopee-extractor

# --- Supabase (banco de usuários e pagamentos) -------------------------------

# URL do projeto Supabase (Project Settings → API).
# Ex.: https://abcdefghij.supabase.co
SUPABASE_URL=

# Service Role Key do Supabase (Project Settings → API → service_role).
# IMPORTANTE: nunca exponha no frontend — é uma chave de admin.
SUPABASE_SERVICE_KEY=

# --- Mercado Pago ------------------------------------------------------------

# Access Token de produção do Mercado Pago.
# Painel: https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=

# (Opcional, mas RECOMENDADO) Secret usado para validar a assinatura
# x-signature dos webhooks do Mercado Pago. Se vazio, a validação é pulada.
# Configure o mesmo valor no painel do MP em "Notificações → Webhooks".
MP_WEBHOOK_SECRET=

# Preço do plano Premium em centavos (default: 990 = R$ 9,90).
PREMIUM_PRICE_CENTS=990

# URL pública base usada para montar o notification_url do Mercado Pago.
# Normalmente igual ao PUBLIC_URL.
# Ex.: https://meu-bot.vercel.app
PUBLIC_BASE_URL=
